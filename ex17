<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Exercício 17</title>
</head>
<body>
    <button id="btn">Clicar</button>
    <p id="cont">0</p>
    <script>
        let c = 0;
        document.getElementById('btn').addEventListener('click', () => {
            c++;
            document.getElementById('cont').innerText = c;
        });
    </script>
</body>
</html>