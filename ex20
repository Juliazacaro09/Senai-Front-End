<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Exercício 20</title>
    <style>
        .box { display: none; }
        .active { display: block; }
    </style>
</head>
<body>
    <button onclick="tab('t1')">1</button>
    <button onclick="tab('t2')">2</button>
    <div id="t1" class="box active">Conteúdo 1</div>
    <div id="t2" class="box">Conteúdo 2</div>
    <script>
        function tab(id) {
            document.querySelectorAll('.box').forEach(d => d.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }
    </script>
</body>
</html>