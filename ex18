<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Exercício 18</title>
    <style>
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); }
        .content { background: white; margin: 15% auto; padding: 20px; width: 200px; }
    </style>
</head>
<body>
    <button id="open">Abrir</button>
    <div id="modal" class="modal"><div class="content"><p>Modal</p></div></div>
    <script>
        const m = document.getElementById('modal');
        document.getElementById('open').addEventListener('click', () => m.style.display = 'block');
        window.addEventListener('click', (e) => { if(e.target == m) m.style.display = 'none'; });
    </script>
</body>
</html>